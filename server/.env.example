# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ─── Database ──────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker (matches docker-compose.yml):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expense_tracker
# Homebrew Postgres on macOS (replace YOUR_MAC_USERNAME):
DATABASE_URL=postgresql://YOUR_MAC_USERNAME@localhost:5432/expense_tracker

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth / JWT ────────────────────────────────────────────────────────────────
# Use a long random string — e.g. `openssl rand -hex 64`
JWT_SECRET=change_me_to_a_long_random_secret
JWT_REFRESH_SECRET=change_me_to_another_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Clerk Auth ────────────────────────────────────────────────────────────────
# 1. Create an app at https://dashboard.clerk.com
# 2. Go to API Keys and copy your keys below
VITE_CLERK_PUBLISHABLE_KEY=pk_test_ZWFnZXItYWtpdGEtMzUuY2xlcmsuYWNjb3VudHMuZGV2JA
CLERK_SECRET_KEY=sk_test_twsxL4wXCQe7QYGBbDSZ6GwWtekkCoKDYJk64vx8lp
# 3. Go to Webhooks → Add Endpoint → copy the signing secret
CLERK_WEBHOOK_SECRET=whsec_ZI5rrYpYNsDYkEiuWadZdFoTmVhp1v9A

# ─── Google OAuth (legacy — now handled inside Clerk dashboard) ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── Gemini AI (optional — AI features) ────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── Email / Resend (optional) ───────────────────────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ─── S3 / Object Storage (optional — receipt uploads) ─────────────────────────
S3_BUCKET=expense-tracker-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Leave blank for AWS; set for S3-compatible providers (MinIO, Cloudflare R2, etc.)
S3_ENDPOINT=

# ─── Currency Exchange (optional) ──────────────────────────────────────────────
# https://www.exchangerate-api.com
EXCHANGE_RATE_API_KEY=
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4
