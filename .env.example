# ──────────────────────────────────
# Database
# ──────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/expense_tracker
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────
# Auth
# ──────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ──────────────────────────────────
# Server
# ──────────────────────────────────
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ──────────────────────────────────
# OpenAI
# ──────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o

# ──────────────────────────────────
# Stripe
# ──────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_TEAM_PRICE_ID=price_team_monthly

# ──────────────────────────────────
# Email (Resend)
# ──────────────────────────────────
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@yourapp.com

# ──────────────────────────────────
# File Storage (S3-compatible)
# ──────────────────────────────────
S3_BUCKET=expense-tracker-uploads
S3_REGION=us-east-1
S3_ACCESS_KEY=your-s3-access-key
S3_SECRET_KEY=your-s3-secret-key
S3_ENDPOINT=

# ──────────────────────────────────
# Currency Exchange API
# ──────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4

# ──────────────────────────────────
# Client (Vite prefixed)
# ──────────────────────────────────
VITE_API_URL=http://localhost:3000/api
VITE_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id
